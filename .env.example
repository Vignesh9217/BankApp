# Backend
SERVER_PORT=8080
SPRING_DATASOURCE_URL=jdbc:mysql://bankapp-anurag-09f9.b.aivencloud.com:16194/defaultdb?sslMode=REQUIRED&enabledTLSProtocols=TLSv1.2&connectTimeout=10000&socketTimeout=30000&tcpKeepAlive=true
